datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String?
  googleId         String?          @unique
  name             String           @unique // This is the character's name/nickname in the game
  
  // Game attributes
  gender           String           // "Masculino", "Feminino", "Outro"
  role             String           // "Professor", "Graduando", "Mestrando", "Doutorando", "Pesquisador", "Funcionário"
  entrySemester    String           // e.g. "2020.1", "2023.2", "Antes de 2018"
  isColab          String           // "Sim", "Não" — se a pessoa é do Colabs
  area             String[]         // Áreas de interesse (multivalor)
  projects         String[]         // Um único projeto no LSD (armazenado como array de 1)
  likesCoffee      String           // "Sim", "Não", "Só energético"
  photoUrl         String?          // Base64 data URL or photo URL

  // Daily game snapshot: the games (LSDLE etc.) read these, NOT the editable
  // fields above. They are promoted from the editable values at most once per day
  // (see syncGameAttributes), so a profile edit only reaches the games the next
  // day. `gameSyncDate` is the "YYYY-MM-DD" the snapshot reflects ("" = never).
  gameGender        String          @default("")
  gameRole          String          @default("")
  gameEntrySemester String          @default("")
  gameIsColab       String          @default("")
  gameArea          String[]        @default([])
  gameProjects      String[]        @default([])
  gameLikesCoffee   String          @default("")
  gamePhotoUrl      String?
  gameSyncDate      String          @default("")

  // Metadata & Activity Tracking
  lastLogin        DateTime         @default(now())
  isActive         Boolean          @default(true)
  isAdmin          Boolean          @default(false)
  emailVerifiedAt  DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  dailyCharacters  DailyCharacter[]
  gameResults      GameResult[]
  dailyProgress    DailyProgress[]
  termoResults     TermoResult[]
  termoProgress    TermoProgress[]
  forcaResults     ForcaResult[]
  forcaProgress    ForcaProgress[]
  streaks          GameStreak[]
  createdProjects  Project[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Catalog of LSD research projects/lines. Users pick from this list (and may
// propose new entries). `User.projects` stores the selected names; member counts
// are derived by aggregating active users' project arrays.
model Project {
  id          String   @id @default(uuid())
  name        String   @unique
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
}

// Per-player, per-game daily streak. `current` counts consecutive days solved
// (resets to 1 after a gap), `best` is the all-time max, `lastDate` is the last
// "YYYY-MM-DD" the player solved that game. One row per (playerId, game).
model GameStreak {
  id        Int      @id @default(autoincrement())
  playerId  String
  player    User     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game      String   // "lsdle" | "termo" | "forca"
  current   Int      @default(0)
  best      Int      @default(0)
  lastDate  String   @default("") // last solved date, "YYYY-MM-DD"
  updatedAt DateTime @updatedAt

  @@unique([playerId, game])
}

model DailyCharacter {
  id          Int      @id @default(autoincrement())
  date        String   @unique // Format: "YYYY-MM-DD"
  characterId String
  character   User     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  // Optional message the person of the day can leave for the players who guess
  // them: a short text and/or an image (base64 data URL). Shown in the victory
  // modal to players who have already solved today's round.
  message     String?
  mediaUrl    String?
  createdAt   DateTime @default(now())
}

// One result per logged-in player per day. Ranking: fewer attempts ranks
// higher; ties broken by shorter durationMs (time from 1st guess to win).
model GameResult {
  id         Int      @id @default(autoincrement())
  date       String   // Format: "YYYY-MM-DD"
  playerId   String
  player     User     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  attempts   Int
  durationMs Int
  createdAt  DateTime @default(now())

  @@unique([date, playerId])
  @@index([date, attempts, durationMs])
}

// Server-authoritative tracking of a player's progress for a given day. Attempts
// and timing are derived here from real guesses (see POST /api/game/guess), so
// the ranking cannot be fabricated by a crafted POST to /api/game/result.
model DailyProgress {
  id           Int       @id @default(autoincrement())
  date         String    // Format: "YYYY-MM-DD"
  playerId     String
  player       User      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  attempts     Int       @default(0)
  firstGuessAt DateTime  @default(now())
  solved       Boolean   @default(false)
  solvedAt     DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([date, playerId])
}

// ── TERMO (Wordle-style) game ────────────────────────────────────────────────
// Termo is fully self-contained (its own daily word, progress and ranking) so it
// never collides with the LSDLE tables above.

// The solution word for a given day. Stored normalized (uppercase, no accents);
// `display` keeps the accented form revealed when the round ends.
model TermoDaily {
  id        Int      @id @default(autoincrement())
  date      String   @unique // Format: "YYYY-MM-DD"
  word      String   // normalized solution, e.g. "TERMO"
  display   String   // accented form to reveal, e.g. "TÉRMO"
  createdAt DateTime @default(now())
}

// Server-authoritative play state for the Termo round, mirroring DailyProgress.
model TermoProgress {
  id           Int       @id @default(autoincrement())
  date         String    // Format: "YYYY-MM-DD"
  playerId     String
  player       User      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  attempts     Int       @default(0)
  firstGuessAt DateTime  @default(now())
  solved       Boolean   @default(false)
  solvedAt     DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([date, playerId])
}

// One Termo result per logged-in player per day. Ranking: fewer attempts ranks
// higher; ties broken by shorter durationMs (time from 1st guess to win).
model TermoResult {
  id         Int      @id @default(autoincrement())
  date       String   // Format: "YYYY-MM-DD"
  playerId   String
  player     User     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  attempts   Int
  durationMs Int
  createdAt  DateTime @default(now())

  @@unique([date, playerId])
  @@index([date, attempts, durationMs])
}

// ── FORCA (Hangman) game ─────────────────────────────────────────────────────
// Self-contained, like Termo: own daily word, progress and ranking.

model ForcaDaily {
  id          Int      @id @default(autoincrement())
  date        String   @unique // Format: "YYYY-MM-DD"
  word        String   // normalized solution
  display     String   // accented form to reveal
  // The registered person you're "saving" by guessing the word (flavor only —
  // unrelated to the answer). Snapshot of name + photo at selection time.
  personName  String?
  personPhoto String?
  createdAt   DateTime @default(now())
}

// Server-authoritative play state. `guessed` holds the letters tried so far
// (normalized, no separator); wrong-count and the solved check derive from it.
model ForcaProgress {
  id           Int       @id @default(autoincrement())
  date         String    // Format: "YYYY-MM-DD"
  playerId     String
  player       User      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  guessed      String    @default("")
  firstGuessAt DateTime  @default(now())
  solved       Boolean   @default(false)
  solvedAt     DateTime?
  updatedAt    DateTime  @updatedAt

  @@unique([date, playerId])
}

// One Forca result per logged-in player per day. Ranking: fewer wrong guesses
// (stored in `attempts`) ranks higher; ties broken by shorter durationMs.
model ForcaResult {
  id         Int      @id @default(autoincrement())
  date       String   // Format: "YYYY-MM-DD"
  playerId   String
  player     User     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  attempts   Int      // number of wrong guesses
  durationMs Int
  createdAt  DateTime @default(now())

  @@unique([date, playerId])
  @@index([date, attempts, durationMs])
}
