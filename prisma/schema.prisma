datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  passwordHash     String?
  googleId         String?          @unique
  name             String           @unique // Player's display name / nickname
  photoUrl         String?          // Base64 data URL or photo URL

  // Metadata & Activity Tracking
  lastLogin        DateTime         @default(now())
  isActive         Boolean          @default(true)
  isAdmin          Boolean          @default(false)
  emailVerifiedAt  DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  showRuns         ShowRun[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

// Simple key/value store for admin-tunable runtime settings (e.g. whether the
// 30-day inactivity rule hides players from the ranking). Read with a code-side
// default so an absent row keeps the historical behavior.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ── O SHOW DA COMPUTAÇÃO ─────────────────────────────────────────────────────
// One row per play-through of the "Show do Milhão"-style quiz. The whole run is
// server-authoritative: the ordered question ids, the current step, the banked
// prize and the lifelines used all live here, so a score can never be fabricated
// by a crafted POST. The ranking reads the best `prize` per player.
model ShowRun {
  id            String    @id @default(cuid())
  playerId      String
  player        User      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  questionIds   String    // ordered csv of the picked question ids (easy → hard)
  currentStep   Int       @default(1) // 1..N, the step being answered next
  prize         Int       @default(0) // banked prize: 0 / guaranteed floor / accumulated
  status        String    @default("playing") // playing | won | stopped | lost
  usedLifelines String    @default("") // csv tokens `type@step` (see server/show.ts)
  durationMs    Int?      // filled when the run ends
  startedAt     DateTime  @default(now())
  stepStartedAt DateTime  @default(now()) // when the current question was served (server timer)
  endedAt       DateTime?

  @@index([playerId, prize])
  @@index([prize, durationMs])
}
