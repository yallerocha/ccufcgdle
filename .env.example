# --- Docker / local ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ccdle
DB_PORT=5432
API_PORT=3001
WEB_PORT=3003
JWT_SECRET=change-me-to-a-long-random-string

# Browser → API directly (Docker / local dev)
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Vercel (frontend) ---
# Dummy URL only for `prisma generate` during build (frontend does not use DB at runtime)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ccdle?schema=public

# Server-side rewrite: Vercel proxies /api/* to the public API URL below.
# Leave NEXT_PUBLIC_API_URL unset on Vercel when using this.
API_URL=https://ccdle-api.onrender.com

# --- API (Railway, Render, Fly, VPS…) ---
PORT=3001
DATABASE_URL=postgresql://user:pass@host:5432/ccdle?schema=public
JWT_SECRET=change-me-to-a-long-random-string
# URL do front na Vercel (várias origens: separadas por vírgula)
CORS_ORIGIN=https://seu-app.vercel.app

# Mock seed (DELETES all users). Only works in Docker Compose with ALLOW_LOCAL_SEED=true.
SEED_DATABASE=false

# Upserts default admin on every API startup (local + production). Set false to disable.
ENSURE_DEFAULT_ADMIN=true

# --- Email (Nodemailer / SMTP) ---
# Verificação real ON por padrão. SKIP_EMAIL_VERIFICATION=true auto-verifica no cadastro (atalho local).
# Docker local sem Gmail: use Mailpit (docker-compose já aponta SMTP_HOST=mailpit) ou SKIP=true.
SKIP_EMAIL_VERIFICATION=false

# --- Gmail (produção no Render) ---
# 1) Ative verificação em 2 etapas na conta Google
# 2) Crie uma "Senha de app" em https://myaccount.google.com/apppasswords
# 3) Coloque os valores REAIS só no .env local (gitignored) ou no painel do Render — NUNCA commite senhas aqui
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu.email@gmail.com
SMTP_PASS=sua-senha-de-app-16-caracteres
EMAIL_FROM=LSD Game Hub <seu.email@gmail.com>

# Alternativa: uma linha só (substitua usuario, senha-de-app e email)
# SMTP_URL=smtp://seu.email@gmail.com:sua-senha-de-app@smtp.gmail.com:587

# URL pública do front (links de verificação e reset de senha nos emails)
APP_URL=https://seu-app.vercel.app

# --- Google OAuth (login com Google) ---
# 1) Crie um projeto em https://console.cloud.google.com/apis/credentials
# 2) Tipo "ID do cliente OAuth" → Aplicativo da Web
# 3) Origens JavaScript autorizadas: http://localhost:3003 e URL do front na Vercel
# 4) Defina GOOGLE_CLIENT_ID na API (Render). O front busca o Client ID em /api/auth/config —
#    não precisa de NEXT_PUBLIC_GOOGLE_CLIENT_ID na Vercel (opcional como atalho local).
#    Formato: 123456789-xxxx.apps.googleusercontent.com (NÃO use GOCSPX-...)
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
# Opcional no front (Docker local / build sem depender da API):
NEXT_PUBLIC_GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com

# --- Docker local: Mailpit (emails de teste em http://localhost:8025) ---
# Deixe SKIP_EMAIL_VERIFICATION=false e use no docker-compose (já configurado):
# SMTP_HOST=mailpit
# SMTP_PORT=1025
# SMTP_SECURE=false
# EMAIL_FROM=LSD Game Hub <noreply@localhost>
