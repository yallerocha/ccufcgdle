# Production-ready Dockerfile for the Next.js frontend (UI only).
FROM node:20-alpine AS base

# Install dependencies only when needed
FROM base AS deps
# libc6-compat for Next.js; python3/make/g++ to compile native deps (better-sqlite3)
RUN apk add --no-cache libc6-compat python3 make g++
WORKDIR /app

COPY package.json package-lock.json ./
COPY prisma ./prisma
COPY prisma.config.ts ./
RUN npm ci --ignore-scripts

# Rebuild the source code only when needed
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# NEXT_PUBLIC_* vars are inlined at build time. NEXT_PUBLIC_API_URL pins an
# exact backend URL (Vercel/custom domains). For Docker/LAN local dev, leave
# it unset and pass NEXT_PUBLIC_API_PORT instead: the browser then derives the
# API host from whatever hostname/IP was used to load the page, so the same
# image works from localhost and from any machine on the local network.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_API_PORT
ENV NEXT_PUBLIC_API_PORT=$NEXT_PUBLIC_API_PORT
ARG NEXT_PUBLIC_GOOGLE_CLIENT_ID
ENV NEXT_PUBLIC_GOOGLE_CLIENT_ID=$NEXT_PUBLIC_GOOGLE_CLIENT_ID

# Prisma Client is only needed to satisfy type-checking during `next build`
# (the frontend never connects to the database at runtime).
ENV DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ccdle?schema=public"
RUN npx prisma generate
RUN npm run build

# Production image, copy all the files and run next
FROM base AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json

USER nextjs

EXPOSE 3000

CMD ["npm", "run", "start", "--", "-p", "3000"]
